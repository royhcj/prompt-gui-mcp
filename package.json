{
  "name": "prompt-gui-mcp",
  "private": true,
  "version": "0.1.2",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "dev:desktop:app": "pnpm --filter desktop tauri:dev",
    "simulate": "node scripts/simulate-with-desktop.mjs",
    "simulate:backend": "pnpm --filter backend simulate"
  }
}
