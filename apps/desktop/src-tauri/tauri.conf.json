{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "i-am-mcp",
  "version": "0.1.0",
  "identifier": "dev.roy.iammcp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "i-am-mcp",
        "width": 920,
        "height": 760,
        "resizable": true,
        "alwaysOnTop": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
